{
  "version": 2,
  "builds": [
    { "src": "api/main.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/index.html", "dest": "/public/index.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/perfil.html", "dest": "/public/perfil.html" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/script.js", "dest": "/public/script.js" },
    { "src": "/logo.png", "dest": "/public/logo.png" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
